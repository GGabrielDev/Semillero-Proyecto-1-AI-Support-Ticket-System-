# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Security & Encryption (Required in production)
# Generate a random 64-character hex key (32 bytes) for encrypting database-driven AI API keys
AI_ENCRYPTION_KEY=your_64_character_hex_key_here

# Legacy AI Provider Fallbacks (Optional)
# Note: AI configurations are now primarily configured and managed through the database/Admin panel.
# The keys below serve as environment-level fallbacks if no database config is active.
AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key
LLAMA_SERVER_BASE_URL=http://localhost:8080
LLAMA_MODEL=llama3
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# n8n
N8N_WEBHOOK_URL=
N8N_WELCOME_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_SYSTEM_EMAIL=n8n-bot@yourdomain.com
N8N_SYSTEM_PASSWORD=your_secure_n8n_system_password

# Cron
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
